<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ShareCart.Controls.TileControl"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Border
        BackgroundColor="{x:Binding Color,
                                    Source={x:Reference Root}}"
        HeightRequest="150"
        WidthRequest="150">
        <VerticalStackLayout Padding="10" Spacing="20">
            <Label
                FontAttributes="Bold"
                Style="{x:DynamicResource BodyLabel}"
                Text="{x:Binding Title,
                                 Source={x:Reference Root}}" />
            <Image Aspect="Center" Source="{x:Binding ImageSource, Source={x:Reference Root}}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
