<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ShareCart.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ShareCart.Views"
    Title="ShareCart"
    Shell.BackgroundColor="{x:AppThemeBinding Light={x:DynamicResource LightSurface},
                                              Dark={x:DynamicResource DarkSurface}}"
    Shell.FlyoutBehavior="Disabled"
    Shell.ForegroundColor="{x:AppThemeBinding Light={x:DynamicResource Primary},
                                              Dark={x:DynamicResource Primary}}"
    Shell.TitleColor="{x:AppThemeBinding Light={x:DynamicResource LightTextPrimary},
                                         Dark={x:DynamicResource DarkTextPrimary}}">

    <ShellContent ContentTemplate="{DataTemplate views:LoginPageView}" Route="LoginPageView" />

    <ShellContent ContentTemplate="{DataTemplate views:HomePageView}" Route="HomePageView" />

</Shell>
