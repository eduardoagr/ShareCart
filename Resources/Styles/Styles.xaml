<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  PAGE BACKGROUND  -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:StaticResource LightBackground}, Dark={x:StaticResource DarkBackground}}" />
    </Style>

    <!--  TEXT STYLES  -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:StaticResource LightTextPrimary}, Dark={x:StaticResource DarkTextPrimary}}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:StaticResource LightTextSecondary}, Dark={x:StaticResource DarkTextSecondary}}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:StaticResource LightTextPrimary}, Dark={x:StaticResource DarkTextPrimary}}" />
    </Style>

    <!--  ICON STYLE  -->
    <Style x:Key="IconLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="Mat" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:StaticResource LightTextSecondary}, Dark={x:StaticResource DarkTextSecondary}}" />
    </Style>

    <!--  PRIMARY BUTTON  -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{x:StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Opacity" Value="1" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#2F6AE0" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  SECONDARY BUTTON  -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:StaticResource LightSurface}, Dark={x:StaticResource DarkSurface}}" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:StaticResource LightTextPrimary}, Dark={x:StaticResource DarkTextPrimary}}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Opacity" Value="1" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light=#E5E7EB, Dark=#2A2E36}" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  TEXT BUTTON  -->
    <Style x:Key="TextButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{x:StaticResource Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Opacity" Value="1" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.7" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  ENTRY  -->
    <Style x:Key="DefaultEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:StaticResource LightInputBackground}, Dark={x:StaticResource DarkInputBackground}}" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:StaticResource LightTextPrimary}, Dark={x:StaticResource DarkTextPrimary}}" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <!--  BORDER  -->
    <Style x:Key="RoundedBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Stroke" Value="{x:AppThemeBinding Light={x:StaticResource LightDivider}, Dark={x:StaticResource DarkDivider}}" />
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:StaticResource LightSurface}, Dark={x:StaticResource DarkSurface}}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!--  DIVIDER  -->
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:StaticResource LightDivider}, Dark={x:StaticResource DarkDivider}}" />
    </Style>

    <!--  ACTIVITY INDICATOR  -->
    <Style x:Key="DefaultActivityIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{x:AppThemeBinding Light={x:StaticResource Primary}, Dark={x:StaticResource Primary}}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="IsVisible" Value="True" />
        <Setter Property="Scale" Value="2.2" />

    </Style>

</ResourceDictionary>