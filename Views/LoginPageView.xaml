<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ShareCart.Views.LoginPageView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ShareCart.Controls"
    xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:sfPopup="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
    xmlns:views="clr-namespace:ShareCart.Views"
    xmlns:vm="clr-namespace:ShareCart.ViewModels"
    x:DataType="vm:LoginPageViewModel">

    <!--  ✅ ROOT GRID  -->
    <Grid>
        <!--  ✅ CENTERED CONTENT  -->
        <VerticalStackLayout
            Padding="16"
            Spacing="32"
            VerticalOptions="Center">

            <!--  Title  -->
            <Label
                HorizontalOptions="Center"
                Style="{x:DynamicResource TitleLabel}"
                Text="{loc:Translate UI_WelcomeBack}" />

            <Label
                HorizontalOptions="Center"
                Style="{x:DynamicResource SubtitleLabel}"
                Text="{loc:Translate UI_SignInToContinue}" />

            <!--  Email  -->
            <controls:RoundedEntryControl
                IsPassword="False"
                Placeholder="{loc:Translate UI_Email}"
                Text="{x:Binding Credentials.Email}" />

            <!--  Password  -->
            <controls:RoundedEntryControl
                IsPassword="True"
                Placeholder="{loc:Translate UI_Password}"
                Text="{x:Binding Credentials.Password}" />

            <!--  Login  -->
            <Button
                Command="{Binding LoginCommand}"
                Style="{x:DynamicResource PrimaryButton}"
                Text="{loc:Translate UI_Login}" />

            <!--  Divider  -->
            <BoxView Margin="0,10" Style="{x:DynamicResource Divider}" />

            <!--  Register  -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Style="{x:DynamicResource BodyLabel}" Text="{loc:Translate UI_NoAccount}" />

                <Button
                    Command="{x:Binding OpenRegisterCommand}"
                    Style="{x:DynamicResource TextButton}"
                    Text="{loc:Translate UI_RegisterHere}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <!--  ✅ BUSY POPUP (FULL OVERLAY)  -->
        <sfPopup:SfPopup
            AnimationMode="Zoom"
            IsOpen="{Binding isBusy}"
            ShowHeader="False"
            Style="{x:DynamicResource DefaultPopupStyle}">

            <sfPopup:SfPopup.ContentTemplate>
                <DataTemplate x:DataType="vm:LoginPageViewModel">
                    <ActivityIndicator IsRunning="True" Style="{x:DynamicResource DefaultActivityIndicator}" />
                </DataTemplate>
            </sfPopup:SfPopup.ContentTemplate>
        </sfPopup:SfPopup>

        <!--  ✅ ERROR POPUP (FULL OVERLAY)  -->
        <sfPopup:SfPopup
            AnimationMode="Zoom"
            AutoCloseDuration="2000"
            HeaderTitle="{loc:Translate UI_GenericAuthError}"
            IsOpen="{Binding isFailed}"
            Style="{x:DynamicResource DefaultPopupStyle}"
            WidthRequest="400">

            <sfPopup:SfPopup.ContentTemplate>
                <DataTemplate x:DataType="vm:LoginPageViewModel">
                    <Grid Margin="0,15,0,0" HorizontalOptions="Center">
                        <Label Style="{x:DynamicResource SubtitleLabel}" Text="{Binding Message}" />
                    </Grid>
                </DataTemplate>
            </sfPopup:SfPopup.ContentTemplate>
        </sfPopup:SfPopup>

        <!--  ✅ REGISTER POPUP  -->
        <views:RegistrationPageView IsOpen="{Binding isRegisterPopupOpen}" />
    </Grid>

</ContentPage>