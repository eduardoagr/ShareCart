<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:editors="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:sfPopup="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup">

    <!--  PAGE BACKGROUND  -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightBackground}, Dark={x:DynamicResource DarkBackground}}" />
    </Style>

    <!--  TEXT STYLES  -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightTextPrimary}, Dark={x:DynamicResource DarkTextPrimary}}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightTextSecondary}, Dark={x:DynamicResource DarkTextSecondary}}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightTextPrimary}, Dark={x:DynamicResource DarkTextPrimary}}" />
    </Style>

    <!--  ICON STYLE  -->
    <Style x:Key="IconLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="Mat" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightTextSecondary}, Dark={x:DynamicResource DarkTextSecondary}}" />
    </Style>

    <!--  PRIMARY BUTTON  -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{x:DynamicResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Opacity" Value="1" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.92" />
                            <Setter Property="BackgroundColor" Value="#2F6AE0" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  SECONDARY BUTTON  -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightSurface}, Dark={x:DynamicResource DarkSurface}}" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightTextPrimary}, Dark={x:DynamicResource DarkTextPrimary}}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Opacity" Value="1" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.92" />
                            <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light=#E5E7EB, Dark=#2A2E36}" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  TEXT BUTTON  -->
    <Style x:Key="TextButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{x:DynamicResource Primary}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Opacity" Value="1" />

        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.92" />
                            <Setter Property="Opacity" Value="0.7" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  ENTRY  -->
    <Style x:Key="DefaultEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightInputBackground}, Dark={x:DynamicResource DarkInputBackground}}" />
        <Setter Property="TextColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightTextPrimary}, Dark={x:DynamicResource DarkTextPrimary}}" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <!--  BORDER  -->
    <Style x:Key="RoundedBorder" TargetType="Border">
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Stroke" Value="{x:AppThemeBinding Light={x:DynamicResource LightDivider}, Dark={x:DynamicResource DarkDivider}}" />
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightSurface}, Dark={x:DynamicResource DarkSurface}}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!--  DIVIDER  -->
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightDivider}, Dark={x:DynamicResource DarkDivider}}" />
    </Style>

    <!--  ACTIVITY INDICATOR  -->
    <Style x:Key="DefaultActivityIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{x:AppThemeBinding Light={x:DynamicResource Primary}, Dark={x:DynamicResource Primary}}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="IsVisible" Value="True" />
        <Setter Property="Scale" Value="2.2" />

    </Style>

    <!--  FLOATING ACTION BUTTON  -->
    <Style x:Key="FloatingActionButton" TargetType="Button">
        <Setter Property="WidthRequest" Value="60" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource Primary}, Dark={x:DynamicResource PrimaryDark}}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="Mat" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Text" Value="&#xE145;" />
        <Setter Property="Shadow">
            <Shadow
                Brush="#80000000"
                Opacity="0.4"
                Radius="12"
                Offset="0,4" />
        </Setter>
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions" Value="End" />
        <Setter Property="Margin" Value="0,0,20,20" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">

                    <VisualState x:Name="Normal" />

                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.92" />
                            <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light=#2659C0, Dark=#101A28}" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>

                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>

    </Style>

    <!--  ICON BUTTON  -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource Primary}, Dark={x:DynamicResource PrimaryDark}}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="Mat" />
        <Setter Property="FontSize" Value="28" />

    </Style>

    <!--  FONTIMAGESOURCE  -->
    <Style TargetType="FontImageSource">
        <Setter Property="FontFamily" Value="Mat" />
        <Setter Property="Color" Value="{AppThemeBinding Light=#5F5E5A, Dark=#B4B2A9}" />
    </Style>

    <Style TargetType="CollectionView">
        <Setter Property="ItemsLayout">
            <Setter.Value>
                <LinearItemsLayout ItemSpacing="8" Orientation="Vertical" />
            </Setter.Value>
        </Setter>

        <Setter Property="BackgroundColor" Value="{x:AppThemeBinding Light={x:DynamicResource LightBackground}, Dark={x:DynamicResource DarkBackground}}" />
    </Style>

    <!--  POPUP  -->
    <Style x:Key="DefaultPopupStyle" TargetType="sfPopup:SfPopup">
        <Setter Property="AnimationMode" Value="Zoom" />

        <!--  PopupStyle (nested object)  -->
        <Setter Property="PopupStyle">
            <Setter.Value>
                <sfPopup:PopupStyle
                    HasShadow="True"
                    HeaderBackground="{x:AppThemeBinding Light={x:DynamicResource LightBackground},
                                                         Dark={x:DynamicResource DarkBackground}}"
                    HeaderTextColor="{x:AppThemeBinding Light={x:StaticResource LightTextPrimary},
                                                        Dark={x:StaticResource DarkTextPrimary}}"
                    MessageBackground="{x:AppThemeBinding Light={x:DynamicResource LightBackground},
                                                          Dark={x:DynamicResource DarkBackground}}"
                    MessageTextAlignment="Center" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="editors:SfComboBox">

        <!--  Editable  -->
        <Setter Property="IsEditable" Value="True" />

        <!--  Clear button icon  -->
        <Setter Property="ClearButtonPath">
            <Setter.Value>
                <Path Data="M1.70711 0.292893C1.31658 -0.097631 0.683417 -0.097631 0.292893 0.292893C-0.097631 0.683417 -0.097631 1.31658 0.292893 1.70711L5.58579 7L0.292893 12.2929C-0.097631 12.6834 -0.097631 13.3166 0.292893 13.7071C0.683417 14.0976 1.31658 14.0976 1.70711 13.7071L7 8.41421L12.2929 13.7071C12.6834 14.0976 13.3166 14.0976 13.7071 13.7071C14.0976 13.3166 14.0976 12.6834 13.7071 12.2929L8.41421 7L13.7071 1.70711C14.0976 1.31658 14.0976 0.683417 13.7071 0.292893C13.3166 -0.097631 12.6834 -0.097631 12.2929 0.292893L7 5.58579L1.70711 0.292893Z" Fill="{AppThemeBinding Dark={StaticResource DarkTextPrimary}, Light={StaticResource LightTextPrimary}}" />
            </Setter.Value>
        </Setter>

    </Style>
</ResourceDictionary>